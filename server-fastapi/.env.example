# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# JWT Configuration (use strong random strings in production)
JWT_SECRET=your-jwt-secret-key-here
SECRET_KEY=your-secret-key-here

# Transport Encryption (must match frontend CryptoJS key)
TRANSPORT_ENCRYPTION_KEY=your-transport-encryption-key-here

# API Configuration
API_PORT=3000
API_BASE_URL=http://localhost:3000
PORT=3000

# CORS Origins (comma-separated, no spaces)
CORS_ORIGINS=http://localhost:4200,http://localhost:4201,http://localhost:4202,http://localhost:4203,http://localhost:4204,http://localhost:4205,http://localhost:4206,http://localhost:4207

# Upload directory
UPLOAD_DIR=uploads

# Timezone
TZ=Asia/Manila

# Email Configuration (for sending emails)
EMAIL_USER=your-email@example.com
EMAIL_PASSWORD=your-email-app-password
